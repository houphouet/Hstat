df <- data.frame(
variete = rep(c("V0_Temoin", "V1", "V2", "V3", "V4"), each = 4),
rendement = c(
3.2, 3.5, 3.1, 3.4,   # V0 Témoin
4.1, 4.3, 3.9, 4.2,   # V1
5.2, 5.0, 5.3, 4.9,   # V2
3.3, 3.6, 3.2, 3.5,   # V3 (proche du témoin)
6.1, 5.8, 6.3, 6.0    # V4
)
library(agricolae)
# 1. Modèle ANOVA
modele <- aov(rendement ~ variete, data = df)
summary(modele)
# 2. Test de Dunnett (V0_Temoin comme référence)
resultat <- dunnett.test(modele, trt = "variete", control = "V0_Temoin")
DunnettTest(rendement ~ variete, data = df, control = "V0_Temoin")
