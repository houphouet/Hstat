## Fichier de citation du package HStat.
## Lu automatiquement par citation("HStat") et toRfBibtex().

citHeader("Pour citer le package HStat dans vos publications, utilisez :")

## Recuperation dynamique de la version et de l'annee depuis le DESCRIPTION,
## avec repli si les metadonnees ne sont pas disponibles.
year <- tryCatch(
  sub("-.*", "", utils::packageDate("HStat")),
  error = function(e) format(Sys.Date(), "%Y")
)
if (is.null(year) || is.na(year) || !nzchar(year))
  year <- format(Sys.Date(), "%Y")

vers <- tryCatch(
  as.character(utils::packageVersion("HStat")),
  error = function(e) "0.2.3"
)

bibentry(
  bibtype  = "Manual",
  title    = paste0("HStat : Application Shiny interactive pour l'analyse statistique"),
  author   = person("Houphouet", "KOUADIO",
                    comment = c(ORCID = "0000-0002-8238-1091")),
  year     = year,
  note     = paste0("Version ", vers),
  url      = "https://github.com/houphouet/hstat",
  key      = "hstat",
  textVersion = paste0(
    "KOUADIO, Houphouet (", year, "). ",
    "HStat : Application Shiny interactive pour l'analyse statistique. ",
    "Version ", vers, ". https://github.com/houphouet/hstat"
  )
)
